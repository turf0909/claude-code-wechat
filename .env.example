# Copy this file to .env and fill in your config (.env is gitignored, won't be committed)
#
# Anthropic API Key (required for SDK mode; optional for Channel mode — omit to use OAuth)
# ANTHROPIC_API_KEY=sk-ant-xxx
#
# API proxy URL (set when using a third-party proxy; leave unset for direct Anthropic API)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
#
# Model (default: auto)
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# WeChat credentials file path (for multi-user setups; default: ~/.claude/channels/wechat/account.json)
# WECHAT_CREDENTIALS_FILE=/path/to/account.json
